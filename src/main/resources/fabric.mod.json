{
  "schemaVersion": 1,
  "id": "cyt-heirlooms-viewer",
  "version": "1.0.1",
  "name": "CYT Heirloom Viewer",
  "description": "A mod used to showcase what items in a gui is an heirloom",
  "authors": ["Oribuin"],
  "environment": "client",
  "accessWidener": "heirloomviewer.accesswidener",
  "entrypoints": {
